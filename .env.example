# PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=attendance
DB_USER=attendance
DB_PASSWORD=attendance

# Полная строка подключения; если не задана, backend собирает её из параметров выше
# DATABASE_URL=postgresql+psycopg2://attendance:attendance@db:5432/attendance

# MinIO (S3-совместимое хранилище роликов и размеченных кадров)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=attendance-clips
# Адрес MinIO, доступный из браузера пользователя (для presigned-ссылок)
MINIO_PUBLIC_ENDPOINT=localhost:9000

# Часовой пояс расписания
TIMEZONE=Europe/Moscow

# Понедельник первой учебной недели семестра; первая неделя считается белой.
# Если семестр начался с зелёной недели, укажите дату на неделю раньше.
SEMESTER_START=2026-02-09

# Сетевая зона камер, которую обслуживает capture-manager из compose
CAPTURE_GROUP=default

# Распознавание загруженных видео и изображений
RECOGNITION_UPLOAD_MAX_SIZE_MB=512
# Для более точной обработки укажите путь к более крупным или обученным весам.
# Имя в backend хранится в результате вместе с заданием; задавайте его согласованно с MODEL_PATH.
MODEL_PATH=yolov8n.pt
# Отключите скачивание при сборке, если MODEL_PATH указывает на файл из volume-монтажа.
DOWNLOAD_MODEL=true
RECOGNITION_MODEL_NAME=yolov8n
RECOGNITION_MODEL_VERSION=8
INFERENCE_IMAGE_SIZE=960
INFERENCE_IOU_THRESHOLD=0.5
INFERENCE_MAX_DETECTIONS=300
